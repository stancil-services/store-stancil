---
import StoreLayout from '../layouts/StoreLayout.astro';
---

<StoreLayout title="Checkout">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Checkout View -->
    <div id="checkout-view">
      <div class="flex items-center gap-3 mb-8">
        <a href="/cart/" class="text-brand-blue hover:text-brand-dark-blue transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </a>
        <h1 class="font-display text-2xl sm:text-3xl font-bold text-brand-navy">Checkout</h1>
      </div>

      <!-- Empty redirect message -->
      <div id="checkout-empty" class="hidden text-center py-16">
        <p class="text-gray-500 mb-4">Your cart is empty. Add items before checking out.</p>
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-brand-dark-blue transition-colors">
          Browse Store
        </a>
      </div>

      <!-- Order Review -->
      <div id="checkout-content" class="hidden space-y-6">
        <!-- Items -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="font-semibold text-brand-navy">Order Items</h2>
          </div>
          <div id="checkout-items" class="divide-y divide-gray-50">
            <!-- Items rendered by JS -->
          </div>
        </div>

        <!-- Credit Breakdown -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h2 class="font-semibold text-brand-navy mb-4">Payment Summary</h2>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-600">Total amount</span>
              <span class="font-semibold text-brand-navy" id="co-total">$0.00</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Credit-eligible items</span>
              <span class="font-semibold text-brand-navy" id="co-eligible">$0.00</span>
            </div>
            <div class="flex justify-between text-brand-green">
              <span>Credit to be applied</span>
              <span class="font-semibold" id="co-credit">-$0.00</span>
            </div>
            <div class="border-t border-gray-100 pt-3 flex justify-between text-base">
              <span class="font-semibold text-brand-navy">Out-of-pocket</span>
              <span class="font-bold text-brand-navy" id="co-oop">$0.00</span>
            </div>
          </div>
          <div id="co-oop-note" class="hidden mt-4 bg-amber-50 border border-amber-200 rounded-lg p-3 text-sm text-amber-800">
            Out-of-pocket charges will be handled by HR.
          </div>
        </div>

        <!-- Order Details -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h2 class="font-semibold text-brand-navy mb-4">Order Details</h2>
          <div class="space-y-4">
            <div>
              <label for="co-location" class="block text-xs text-gray-500 uppercase tracking-wider mb-1">
                Your Location
              </label>
              <select
                id="co-location"
                class="w-full sm:w-72 px-3 py-2 border border-gray-200 rounded-lg text-sm text-brand-navy focus:outline-none focus:ring-2 focus:ring-brand-blue disabled:opacity-50"
              >
                <option value="">— Select location —</option>
              </select>
            </div>
            <div>
              <label for="co-manager" class="block text-xs text-gray-500 uppercase tracking-wider mb-1">
                Manager
              </label>
              <select
                id="co-manager"
                class="w-full sm:w-72 px-3 py-2 border border-gray-200 rounded-lg text-sm text-brand-navy focus:outline-none focus:ring-2 focus:ring-brand-blue disabled:opacity-50"
                disabled
              >
                <option value="">— Select location first —</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex flex-col sm:flex-row gap-3">
          <button
            id="place-order-btn"
            class="flex-1 px-6 py-3.5 bg-brand-blue text-white font-semibold rounded-lg hover:bg-brand-dark-blue transition-colors text-center focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Place Order
          </button>
          <a
            href="/cart/"
            class="px-6 py-3.5 border border-gray-200 text-brand-navy font-medium rounded-lg hover:bg-gray-50 transition-colors text-center"
          >
            Back to Cart
          </a>
        </div>

        <!-- Error message -->
        <div id="checkout-error" class="hidden bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-700"></div>
      </div>
    </div>

    <!-- Confirmation View -->
    <div id="confirmation-view" class="hidden text-center py-12">
      <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-green-100 flex items-center justify-center">
        <svg class="w-10 h-10 text-brand-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h2 class="font-display text-2xl font-bold text-brand-navy mb-2">Order Placed!</h2>
      <p class="text-gray-500 mb-2">Your order has been submitted for processing.</p>
      <p class="text-sm text-brand-navy font-medium mb-1">
        Order <span id="conf-order-id" class="font-bold">#---</span>
      </p>
      <div class="inline-flex flex-col gap-1 text-sm text-gray-600 mb-8">
        <span>Credit used: <strong class="text-brand-green" id="conf-credit">$0.00</strong></span>
        <span>Out-of-pocket: <strong class="text-brand-navy" id="conf-oop">$0.00</strong></span>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          id="conf-view-link"
          href="/orders/"
          class="px-6 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-brand-dark-blue transition-colors"
        >
          View Order
        </a>
        <a
          href="/"
          class="px-6 py-3 border border-gray-200 text-brand-navy font-medium rounded-lg hover:bg-gray-50 transition-colors"
        >
          Continue Shopping
        </a>
      </div>
    </div>
  </div>

  <!-- Credit Over-Limit Modal -->
  <div id="credit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <!-- Backdrop -->
    <div id="credit-modal-backdrop" class="absolute inset-0 bg-black/50"></div>
    <!-- Card -->
    <div class="relative bg-white rounded-xl shadow-xl w-full max-w-md p-6">
      <!-- Language toggle -->
      <div class="flex justify-end mb-4">
        <div class="flex items-center gap-1 text-xs font-medium">
          <button id="lang-en" class="px-2 py-1 rounded transition-colors">EN</button>
          <span class="text-gray-300">|</span>
          <button id="lang-es" class="px-2 py-1 rounded transition-colors">ES</button>
        </div>
      </div>
      <!-- Title -->
      <h3 id="modal-title" class="font-display text-lg font-bold text-brand-navy mb-3"></h3>
      <!-- Body -->
      <p id="modal-body" class="text-sm text-gray-600 mb-6 leading-relaxed"></p>
      <!-- Buttons -->
      <div class="flex flex-col sm:flex-row gap-3">
        <button
          id="modal-accept"
          class="flex-1 px-5 py-3 bg-brand-blue text-white font-semibold rounded-lg hover:bg-brand-dark-blue transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-blue"
        ></button>
        <button
          id="modal-cancel"
          class="flex-1 px-5 py-3 border border-gray-200 text-brand-navy font-medium rounded-lg hover:bg-gray-50 transition-colors"
        ></button>
      </div>
    </div>
  </div>
</StoreLayout>

<script>
  const CART_KEY = 'stancil-cart';
  const LANG_KEY = 'stancil-lang';

  let creditTotal = 200;
  let creditUsed = 0;
  let lang: 'en' | 'es' = (localStorage.getItem(LANG_KEY) as 'en' | 'es') || 'en';

  // Location / manager state
  let profileLocation = '';
  let profileManagerName = '';
  let profileManagerEmail = '';

  const i18n = {
    en: {
      title: 'Credit Limit Notice',
      body: (remaining: string, oop: string) =>
        `Your annual credit balance is ${remaining}. This order includes ${oop} out-of-pocket, which will be deducted from your paycheck. Do you want to proceed?`,
      accept: 'Accept & Place Order',
      cancel: 'Cancel',
    },
    es: {
      title: 'Aviso de Límite de Crédito',
      body: (remaining: string, oop: string) =>
        `Tu saldo de crédito anual es ${remaining}. Esta orden incluye ${oop} de gasto propio, que se deducirá de tu cheque de pago. ¿Deseas continuar?`,
      accept: 'Aceptar y Realizar Pedido',
      cancel: 'Cancelar',
    },
  };

  function getCart(): any[] {
    try {
      return JSON.parse(localStorage.getItem(CART_KEY) || '[]');
    } catch {
      return [];
    }
  }

  function escapeHtml(str: string | null | undefined): string {
    if (!str) return '';
    const div = document.createElement('div');
    div.textContent = String(str);
    return div.innerHTML;
  }

  function formatPrice(cents: number): string {
    return '$' + (cents / 100).toFixed(2);
  }

  function renderCheckout() {
    const cart = getCart();
    const emptyEl = document.getElementById('checkout-empty');
    const contentEl = document.getElementById('checkout-content');
    const itemsEl = document.getElementById('checkout-items');

    if (!emptyEl || !contentEl || !itemsEl) return;

    if (cart.length === 0) {
      emptyEl.classList.remove('hidden');
      contentEl.classList.add('hidden');
      return;
    }

    emptyEl.classList.add('hidden');
    contentEl.classList.remove('hidden');

    itemsEl.innerHTML = cart.map(item => `
      <div class="px-6 py-4 flex items-center gap-4">
        <img
          src="${escapeHtml(item.imageUrl) || '/images/placeholder-product.png'}"
          alt="${escapeHtml(item.productName)}"
          class="w-10 h-10 rounded-lg object-cover shrink-0 bg-gray-100"
          onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 48 48%22%3E%3Crect fill=%22%23f3f4f6%22 width=%2248%22 height=%2248%22/%3E%3Ctext x=%2224%22 y=%2228%22 text-anchor=%22middle%22 fill=%22%239ca3af%22 font-size=%2214%22%3E?%3C/text%3E%3C/svg%3E'"
        />
        <div class="flex-1 min-w-0">
          <p class="font-medium text-brand-navy text-sm truncate">${escapeHtml(item.productName)}</p>
          <p class="text-xs text-gray-500">${[item.size, item.color].filter(Boolean).map((v: string) => escapeHtml(v)).join(' / ')} &times; ${item.quantity}</p>
        </div>
        <span class="text-sm font-bold text-brand-navy shrink-0">${formatPrice(item.price * item.quantity)}</span>
      </div>
    `).join('');

    updateTotals(cart);
  }

  function calcTotals(cart: any[]) {
    const total = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
    const eligibleTotal = cart
      .filter(item => item.creditEligible)
      .reduce((sum, item) => sum + item.price * item.quantity, 0);
    const availableCredit = (creditTotal - creditUsed) * 100;
    const creditApplied = Math.min(eligibleTotal, Math.max(0, availableCredit));
    const outOfPocket = total - creditApplied;
    return { total, eligibleTotal, creditApplied, outOfPocket };
  }

  function updateTotals(cart: any[]) {
    const { total, eligibleTotal, creditApplied, outOfPocket } = calcTotals(cart);

    const totalEl = document.getElementById('co-total');
    const eligibleEl = document.getElementById('co-eligible');
    const creditEl = document.getElementById('co-credit');
    const oopEl = document.getElementById('co-oop');
    const oopNote = document.getElementById('co-oop-note');

    if (totalEl) totalEl.textContent = formatPrice(total);
    if (eligibleEl) eligibleEl.textContent = formatPrice(eligibleTotal);
    if (creditEl) creditEl.textContent = '-' + formatPrice(creditApplied);
    if (oopEl) oopEl.textContent = formatPrice(outOfPocket);
    if (oopNote) {
      if (outOfPocket > 0) oopNote.classList.remove('hidden');
      else oopNote.classList.add('hidden');
    }
  }

  async function fetchCredit() {
    try {
      const res = await fetch('/api/profile');
      if (res.ok) {
        const data = await res.json();
        if (data.profile) {
          creditTotal = data.profile.yearly_credit || 200;
          creditUsed = data.profile.credit_used || 0;
          profileLocation = data.profile.primary_location || '';
          profileManagerName = data.profile.manager_name || '';
          profileManagerEmail = data.profile.manager_email || '';
        }
      }
    } catch {
      // Use defaults
    }
    updateTotals(getCart());
  }

  async function loadLocations() {
    const locationSelect = document.getElementById('co-location') as HTMLSelectElement | null;
    if (!locationSelect) return;

    try {
      const res = await fetch('/api/locations');
      if (res.ok) {
        const data = await res.json();
        locationSelect.innerHTML = '<option value="">— Select location —</option>' +
          (data.locations as string[]).map((name: string) =>
            `<option value="${name}"${name === profileLocation ? ' selected' : ''}>${name}</option>`
          ).join('');

        if (profileLocation) {
          await loadManagers(profileLocation);
        }
      }
    } catch {
      // leave default option
    }
  }

  async function loadManagers(location: string) {
    const managerSelect = document.getElementById('co-manager') as HTMLSelectElement | null;
    if (!managerSelect) return;

    if (!location) {
      managerSelect.innerHTML = '<option value="">— Select location first —</option>';
      managerSelect.disabled = true;
      return;
    }

    managerSelect.disabled = true;
    managerSelect.innerHTML = '<option value="">Loading...</option>';

    try {
      const res = await fetch(`/api/managers?location=${encodeURIComponent(location)}`);
      if (res.ok) {
        const data = await res.json();
        const managers = data.managers as { manager_name: string; manager_email: string }[];

        if (managers.length === 0) {
          managerSelect.innerHTML = '<option value="">— No managers found —</option>';
        } else {
          managerSelect.innerHTML = '<option value="">— Select manager —</option>' +
            managers.map(m => {
              const val = `${m.manager_name}|${m.manager_email}`;
              const isDefault = m.manager_email === profileManagerEmail;
              return `<option value="${val}"${isDefault ? ' selected' : ''}>${m.manager_name}</option>`;
            }).join('');
        }
        managerSelect.disabled = false;
      }
    } catch {
      managerSelect.innerHTML = '<option value="">— Error loading managers —</option>';
      managerSelect.disabled = false;
    }
  }

  // The actual API call + confirmation display
  async function submitOrder() {
    const btn = document.getElementById('place-order-btn') as HTMLButtonElement;
    const errorEl = document.getElementById('checkout-error');
    if (!btn) return;

    btn.disabled = true;
    btn.textContent = 'Placing order...';
    if (errorEl) errorEl.classList.add('hidden');

    const cart = getCart();
    const { creditApplied, outOfPocket } = calcTotals(cart);

    const locationSelect = document.getElementById('co-location') as HTMLSelectElement | null;
    const managerSelect = document.getElementById('co-manager') as HTMLSelectElement | null;
    const selectedLocation = locationSelect?.value || '';
    const managerVal = managerSelect?.value || '';
    const [selectedManagerName, selectedManagerEmail] = managerVal.includes('|')
      ? managerVal.split('|')
      : [managerVal, ''];

    try {
      const res = await fetch('/api/cart/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          items: cart,
          location: selectedLocation,
          managerName: selectedManagerName,
          managerEmail: selectedManagerEmail,
        }),
      });

      const data = await res.json();

      if (!res.ok || !data.success) {
        throw new Error(data.error || 'Failed to place order');
      }

      localStorage.removeItem(CART_KEY);
      window.dispatchEvent(new Event('cart-updated'));

      const checkoutView = document.getElementById('checkout-view');
      const confirmView = document.getElementById('confirmation-view');
      const confId = document.getElementById('conf-order-id');
      const confCredit = document.getElementById('conf-credit');
      const confOop = document.getElementById('conf-oop');
      const confLink = document.getElementById('conf-view-link') as HTMLAnchorElement;

      if (checkoutView) checkoutView.classList.add('hidden');
      if (confirmView) confirmView.classList.remove('hidden');
      if (confId) confId.textContent = `#${data.orderId || data.order?.id}`;
      if (confCredit) confCredit.textContent = formatPrice(creditApplied);
      if (confOop) confOop.textContent = formatPrice(outOfPocket);
      if (confLink) confLink.href = `/orders/${data.orderId || data.order?.id}`;
    } catch (err: any) {
      if (errorEl) {
        errorEl.textContent = err.message || 'Something went wrong. Please try again.';
        errorEl.classList.remove('hidden');
      }
      btn.disabled = false;
      btn.textContent = 'Place Order';
    }
  }

  // Intercepts when out-of-pocket > 0 and shows the modal first
  function placeOrder() {
    const cart = getCart();
    const { outOfPocket } = calcTotals(cart);

    if (outOfPocket > 0) {
      showCreditModal(outOfPocket);
    } else {
      submitOrder();
    }
  }

  // ---- Modal ----

  function setLang(newLang: 'en' | 'es') {
    lang = newLang;
    localStorage.setItem(LANG_KEY, lang);
    updateLangButtons();
  }

  function updateLangButtons() {
    const enBtn = document.getElementById('lang-en');
    const esBtn = document.getElementById('lang-es');
    if (enBtn) {
      enBtn.className = lang === 'en'
        ? 'px-2 py-1 rounded bg-brand-blue text-white transition-colors'
        : 'px-2 py-1 rounded text-gray-500 hover:text-brand-navy transition-colors';
    }
    if (esBtn) {
      esBtn.className = lang === 'es'
        ? 'px-2 py-1 rounded bg-brand-blue text-white transition-colors'
        : 'px-2 py-1 rounded text-gray-500 hover:text-brand-navy transition-colors';
    }
  }

  function showCreditModal(outOfPocket: number) {
    const remaining = Math.max(0, (creditTotal - creditUsed) * 100);
    const t = i18n[lang];

    const titleEl = document.getElementById('modal-title');
    const bodyEl = document.getElementById('modal-body');
    const acceptEl = document.getElementById('modal-accept');
    const cancelEl = document.getElementById('modal-cancel');

    if (titleEl) titleEl.textContent = t.title;
    if (bodyEl) bodyEl.textContent = t.body(formatPrice(remaining), formatPrice(outOfPocket));
    if (acceptEl) acceptEl.textContent = t.accept;
    if (cancelEl) cancelEl.textContent = t.cancel;

    updateLangButtons();
    document.getElementById('credit-modal')?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('credit-modal')?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  // ---- Wire up event listeners ----

  renderCheckout();
  // fetchCredit populates profileLocation/Manager, then loadLocations uses them
  fetchCredit().then(() => loadLocations());
  updateLangButtons();

  document.getElementById('co-location')?.addEventListener('change', (e) => {
    const loc = (e.target as HTMLSelectElement).value;
    loadManagers(loc);
  });

  document.getElementById('place-order-btn')?.addEventListener('click', placeOrder);

  document.getElementById('modal-accept')?.addEventListener('click', () => {
    closeModal();
    submitOrder();
  });

  document.getElementById('modal-cancel')?.addEventListener('click', closeModal);
  document.getElementById('credit-modal-backdrop')?.addEventListener('click', closeModal);

  document.getElementById('lang-en')?.addEventListener('click', () => {
    setLang('en');
    // Re-populate modal text if it's open
    const modal = document.getElementById('credit-modal');
    if (modal && !modal.classList.contains('hidden')) {
      const cart = getCart();
      const { outOfPocket } = calcTotals(cart);
      showCreditModal(outOfPocket);
    }
  });

  document.getElementById('lang-es')?.addEventListener('click', () => {
    setLang('es');
    const modal = document.getElementById('credit-modal');
    if (modal && !modal.classList.contains('hidden')) {
      const cart = getCart();
      const { outOfPocket } = calcTotals(cart);
      showCreditModal(outOfPocket);
    }
  });
</script>
