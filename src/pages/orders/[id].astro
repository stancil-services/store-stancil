---
import StoreLayout from '../../layouts/StoreLayout.astro';

const { id } = Astro.params;
const userEmail = Astro.locals.userEmail;
const db = Astro.locals.runtime.env.STORE_DB;

// Fetch order
let order: any = null;
let items: any[] = [];
let employeeProfile: any = null;

try {
  const orderResult = await db
    .prepare('SELECT * FROM orders WHERE id = ?')
    .bind(id)
    .first();
  order = orderResult;

  if (order) {
    const itemsResult = await db
      .prepare(`
        SELECT oi.*, p.name as product_name, p.image_url
        FROM order_items oi
        JOIN products p ON p.id = oi.product_id
        WHERE oi.order_id = ?
      `)
      .bind(id)
      .all();
    items = itemsResult.results || [];

    const profileResult = await db
      .prepare('SELECT display_name, first_name, last_name, primary_location, manager_name FROM profiles WHERE email = ?')
      .bind(order.employee_email)
      .first();
    employeeProfile = profileResult;
  }
} catch (err) {
  console.error('Error fetching order:', err);
}

if (!order) {
  return Astro.redirect('/orders/');
}

// Verify ownership: order must belong to the authenticated user
if ((order as any).employee_email?.toLowerCase() !== userEmail.toLowerCase()) {
  return Astro.redirect('/orders/');
}

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    weekday: 'long',
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  });
}

function formatPrice(cents: number): string {
  return '$' + (cents / 100).toFixed(2);
}

const status = (order.status || 'pending').toLowerCase();
const statusStyles: Record<string, string> = {
  pending: 'bg-amber-100 text-amber-800',
  confirmed: 'bg-blue-100 text-blue-800',
  processing: 'bg-purple-100 text-purple-800',
  fulfilled: 'bg-green-100 text-green-800',
  cancelled: 'bg-red-100 text-red-800',
};
const badgeClass = statusStyles[status] || statusStyles.pending;

const itemStatusStyles: Record<string, string> = {
  pending: 'bg-amber-100 text-amber-800',
  fulfilled: 'bg-green-100 text-green-800',
};

const outOfPocket = order.out_of_pocket || 0;
---

<StoreLayout title={`Order #${id}`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
      <a href="/orders/" class="hover:text-brand-blue transition-colors">My Orders</a>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
      <span class="text-brand-navy font-medium">Order #{id}</span>
    </nav>

    <!-- Order Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-8">
      <div>
        <h1 class="font-display text-2xl sm:text-3xl font-bold text-brand-navy">Order #{id}</h1>
        <p class="text-sm text-gray-500 mt-1">{formatDate(order.created_at)}</p>
      </div>
      <span class={`inline-flex self-start px-3 py-1 rounded-full text-sm font-medium capitalize ${badgeClass}`}>
        {status}
      </span>
    </div>

    <!-- Order Summary Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
      <h2 class="font-semibold text-brand-navy mb-4">Order Summary</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 text-sm">
        <div>
          <p class="text-gray-500">Total</p>
          <p class="font-bold text-brand-navy text-lg">{formatPrice(order.total_amount || 0)}</p>
        </div>
        <div>
          <p class="text-gray-500">Credit applied</p>
          <p class="font-bold text-brand-green text-lg">{formatPrice(order.credit_used || 0)}</p>
        </div>
        <div>
          <p class="text-gray-500">Out-of-pocket</p>
          <p class="font-bold text-brand-navy text-lg">{formatPrice(outOfPocket)}</p>
        </div>
      </div>
      {order.order_notes && (
        <div class="mt-4 pt-4 border-t border-gray-100">
          <p class="text-sm text-gray-500">Notes</p>
          <p class="text-sm text-brand-navy mt-1">{order.order_notes}</p>
        </div>
      )}
      {employeeProfile && (
        <div class="mt-4 pt-4 border-t border-gray-100">
          <dl class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
            <div>
              <dt class="text-xs text-gray-500 uppercase tracking-wider">Employee</dt>
              <dd class="font-medium text-brand-navy mt-0.5">
                {employeeProfile.display_name || [employeeProfile.first_name, employeeProfile.last_name].filter(Boolean).join(' ') || '--'}
              </dd>
            </div>
            <div>
              <dt class="text-xs text-gray-500 uppercase tracking-wider">Location</dt>
              <dd class="font-medium text-brand-navy mt-0.5">{employeeProfile.primary_location || '--'}</dd>
            </div>
            <div>
              <dt class="text-xs text-gray-500 uppercase tracking-wider">Manager</dt>
              <dd class="font-medium text-brand-navy mt-0.5">{employeeProfile.manager_name || '--'}</dd>
            </div>
          </dl>
        </div>
      )}
    </div>

    <!-- Line Items -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="font-semibold text-brand-navy">Items ({items.length})</h2>
      </div>

      <!-- Desktop Table -->
      <div class="hidden sm:block">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 text-left text-gray-500">
              <th class="px-6 py-3 font-medium">Product</th>
              <th class="px-6 py-3 font-medium">Size / Color</th>
              <th class="px-6 py-3 font-medium text-center">Qty</th>
              <th class="px-6 py-3 font-medium text-right">Price</th>
              <th class="px-6 py-3 font-medium text-right">Total</th>
              <th class="px-6 py-3 font-medium text-right">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            {items.map((item: any) => {
              const itemStatus = (item.status || 'pending').toLowerCase();
              const itemBadge = itemStatusStyles[itemStatus] || itemStatusStyles.pending;
              return (
                <tr>
                  <td class="px-6 py-4">
                    <div class="flex items-center gap-3">
                      <img
                        src={item.image_url || '/images/placeholder-product.png'}
                        alt={item.product_name}
                        class="w-10 h-10 rounded-lg object-cover bg-gray-100"
                      />
                      <span class="font-medium text-brand-navy">{item.product_name}</span>
                    </div>
                  </td>
                  <td class="px-6 py-4 text-gray-600">
                    {[item.size, item.color].filter(Boolean).join(' / ') || '--'}
                  </td>
                  <td class="px-6 py-4 text-center">{item.quantity}</td>
                  <td class="px-6 py-4 text-right font-medium text-brand-navy">{formatPrice(item.price || 0)}</td>
                  <td class="px-6 py-4 text-right font-bold text-brand-navy">{formatPrice((item.price || 0) * (item.quantity || 1))}</td>
                  <td class="px-6 py-4 text-right">
                    <span class={`inline-flex px-2 py-0.5 rounded-full text-xs font-medium capitalize ${itemBadge}`}>
                      {itemStatus}
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <!-- Mobile Cards -->
      <div class="sm:hidden divide-y divide-gray-50">
        {items.map((item: any) => {
          const itemStatus = (item.status || 'pending').toLowerCase();
          const itemBadge = itemStatusStyles[itemStatus] || itemStatusStyles.pending;
          return (
            <div class="p-4 flex items-start gap-3">
              <img
                src={item.image_url || '/images/placeholder-product.png'}
                alt={item.product_name}
                class="w-12 h-12 rounded-lg object-cover bg-gray-100 shrink-0"
              />
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2">
                  <p class="font-medium text-brand-navy text-sm truncate">{item.product_name}</p>
                  <span class={`inline-flex px-2 py-0.5 rounded-full text-xs font-medium capitalize shrink-0 ${itemBadge}`}>
                    {itemStatus}
                  </span>
                </div>
                <p class="text-xs text-gray-500 mt-0.5">
                  {[item.size, item.color].filter(Boolean).join(' / ')} &times; {item.quantity}
                </p>
                <p class="text-sm font-bold text-brand-navy mt-1">{formatPrice((item.price || 0) * (item.quantity || 1))}</p>
                {item.order_item_notes && (
                  <p class="text-xs text-gray-500 mt-1">{item.order_item_notes}</p>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</StoreLayout>
